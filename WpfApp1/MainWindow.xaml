<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детский санаторий - Курсовой проект Ивановой Л.В." 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Background="#FF6B9DCD">
            <Button Content="👥 Люди" Command="{Binding OpenPeopleCommand}" 
                    Margin="5" Padding="15,5" FontSize="14"/>
            <Button Content="🧒 Дети" Command="{Binding OpenChildrenCommand}" 
                    Margin="5" Padding="15,5" FontSize="14"/>
            <Button Content="📋 Бронирования" Command="{Binding OpenBookingCommand}" 
                    Margin="5" Padding="15,5" FontSize="14"/>
        </StackPanel>

        <ContentControl x:Name="ContentArea" Grid.Row="1" Margin="10"/>
    </Grid>
</Window>