<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детский санаторий - Курсовой проект Ивановой Л.В." 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с информацией о пользователе -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{Binding UserDisplayName}" 
                           Foreground="White" 
                           FontSize="16" 
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>

                <TextBlock Grid.Column="1" 
                           Text="{Binding UserRoleDisplay}" 
                           Foreground="#3498DB" 
                           FontSize="14" 
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"/>
            </Grid>
        </Border>

        <!-- Меню (кнопки меняются в зависимости от роли) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10" Background="#3498DB">
            <!-- Администратор: все кнопки -->
            <Button Content="👥 Пользователи" 
                    Command="{Binding OpenPeopleCommand}" 
                    Margin="5" Padding="15,5" FontSize="14"
                    Visibility="{Binding CanManageUsers, Converter={StaticResource BoolToVis}}"/>

            <Button Content="🧒 Дети" 
                    Command="{Binding OpenChildrenCommand}" 
                    Margin="5" Padding="15,5" FontSize="14"
                    Visibility="{Binding CanViewChildren, Converter={StaticResource BoolToVis}}"/>

            <Button Content="📋 Бронирования" 
                    Command="{Binding OpenBookingCommand}" 
                    Margin="5" Padding="15,5" FontSize="14"
                    Visibility="{Binding CanViewBookings, Converter={StaticResource BoolToVis}}"/>

            <Button Content="🏥 Учреждения" 
                    Command="{Binding OpenInstitutionsCommand}" 
                    Margin="5" Padding="15,5" FontSize="14"
                    Visibility="{Binding CanManageInstitutions, Converter={StaticResource BoolToVis}}"/>

            <Button Content="📊 Отчеты" 
                    Command="{Binding OpenReportsCommand}" 
                    Margin="5" Padding="15,5" FontSize="14"
                    Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVis}}"/>

            <Button Content="🚪 Выход" 
                    Command="{Binding LogoutCommand}" 
                    Margin="5,5,15,5" Padding="15,5" FontSize="14"
                    HorizontalAlignment="Right"
                    Background="#e74c3c" Foreground="White"/>
        </StackPanel>

        <!-- Область контента -->
        <ContentControl x:Name="ContentArea" Grid.Row="2" Margin="10"/>
    </Grid>
</Window>