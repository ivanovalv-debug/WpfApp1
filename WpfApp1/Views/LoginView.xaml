<Window x:Class="WpfApp1.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему - Детский санаторий" 
        Height="400" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔐 Авторизация" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Логин:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="txtLogin" Height="30" Margin="0,0,0,15" 
                     FontSize="14" Padding="5"/>

            <TextBlock Text="Пароль:" Margin="0,0,0,5" FontWeight="Bold"/>
            <PasswordBox x:Name="txtPassword" Height="30" Margin="0,0,0,20" 
                         FontSize="14" Padding="5"/>

            <Button Content="Войти" Height="40" FontSize="16" 
                    Command="{Binding LoginCommand}"
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,0,10"/>

            <Button Content="Выход" Height="35" FontSize="14"
                    Command="{Binding ExitCommand}"
                    Background="#f44336" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" 
                   Foreground="Red" 
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>